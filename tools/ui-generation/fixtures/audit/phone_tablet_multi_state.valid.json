{
  "schema_version": 1,
  "document_id": "fixture.phone_tablet_multi_state",
  "metadata": {
    "title": "Phone and tablet visible-state audit fixture",
    "budget_profile": "mobile_baseline_v1"
  },
  "assets": {},
  "tokens": {},
  "root": {
    "type": "container",
    "id": "page.root",
    "layout": {
      "direction": "column",
      "width": { "percent": 100 },
      "height": { "percent": 100 },
      "gap": { "px": 20 },
      "padding": { "all": { "px": 24 } }
    },
    "style": { "role": "page" },
    "children": [
      {
        "type": "text",
        "id": "page.initial",
        "content": { "literal": "Ready" },
        "layout": {
          "display": "flex",
          "width": { "px": 240 },
          "height": { "px": 48 }
        },
        "style": { "text_role": "title" }
      },
      {
        "type": "text",
        "id": "page.loading",
        "content": { "literal": "Loading" },
        "layout": {
          "display": "none",
          "width": { "px": 240 },
          "height": { "px": 48 }
        },
        "style": { "text_role": "title" }
      },
      {
        "type": "text",
        "id": "page.empty",
        "content": { "literal": "Nothing available" },
        "layout": {
          "display": "none",
          "width": { "px": 300 },
          "height": { "px": 48 }
        },
        "style": { "text_role": "title" }
      },
      {
        "type": "text",
        "id": "page.error",
        "content": { "literal": "Unable to load" },
        "layout": {
          "display": "none",
          "width": { "px": 300 },
          "height": { "px": 48 }
        },
        "style": {
          "text_role": "title",
          "inline": {
            "background": {
              "kind": "solid",
              "color": { "kind": "literal", "value": "#b42318" }
            }
          }
        }
      },
      {
        "type": "text",
        "id": "page.selected",
        "content": { "literal": "Selected" },
        "layout": {
          "display": "none",
          "width": { "px": 240 },
          "height": { "px": 48 }
        },
        "style": { "text_role": "title" }
      },
      {
        "type": "text",
        "id": "page.disabled",
        "content": { "literal": "Unavailable" },
        "layout": {
          "display": "none",
          "width": { "px": 240 },
          "height": { "px": 48 }
        },
        "style": { "text_role": "title" }
      },
      {
        "type": "modal",
        "id": "page.modal",
        "cancellable": true,
        "component": {
          "slots": {
            "title": { "kind": "text", "content": { "literal": "Confirm action" } },
            "body": { "kind": "text", "content": { "literal": "This visible modal fixture uses the formal modal node." } }
          }
        },
        "layout": {
          "display": "none",
          "width": { "percent": 100 },
          "min_height": { "px": 176 },
          "padding": { "all": { "px": 24 } }
        },
        "style": {
          "inline": {
            "background": {
              "kind": "solid",
              "color": { "kind": "literal", "value": "#172a45" }
            }
          }
        }
      }
    ]
  },
  "states": [
    {
      "id": "loading",
      "overrides": [
        { "node_id": "page.initial", "set": { "layout": { "display": "none" } } },
        { "node_id": "page.loading", "set": { "layout": { "display": "flex" } } }
      ]
    },
    {
      "id": "empty",
      "overrides": [
        { "node_id": "page.initial", "set": { "layout": { "display": "none" } } },
        { "node_id": "page.empty", "set": { "layout": { "display": "flex" } } }
      ]
    },
    {
      "id": "error",
      "overrides": [
        { "node_id": "page.initial", "set": { "layout": { "display": "none" } } },
        { "node_id": "page.error", "set": { "layout": { "display": "flex" } } }
      ]
    },
    {
      "id": "fixture.selected",
      "overrides": [
        { "node_id": "page.initial", "set": { "layout": { "display": "none" } } },
        { "node_id": "page.selected", "set": { "layout": { "display": "flex" } } }
      ]
    },
    {
      "id": "fixture.disabled",
      "overrides": [
        { "node_id": "page.initial", "set": { "layout": { "display": "none" } } },
        { "node_id": "page.disabled", "set": { "layout": { "display": "flex" } } }
      ]
    },
    {
      "id": "fixture.modal",
      "overrides": [
        { "node_id": "page.initial", "set": { "layout": { "display": "none" } } },
        { "node_id": "page.modal", "set": { "layout": { "display": "flex" } } }
      ]
    }
  ],
  "responsive": [
    {
      "id": "phone_portrait",
      "when": {
        "width_class": "compact",
        "orientation": "portrait"
      },
      "overrides": [
        {
          "node_id": "page.root",
          "set": { "layout": { "gap": { "px": 12 } } }
        }
      ]
    },
    {
      "id": "tablet_landscape",
      "when": {
        "width_class": "expanded",
        "orientation": "landscape"
      },
      "overrides": [
        {
          "node_id": "page.root",
          "set": { "layout": { "direction": "row" } }
        }
      ]
    }
  ]
}
